PORT=4000
JWT_SECRET=change-me
DATABASE_URL=postgresql://coord:coord@localhost:5432/coorddb?schema=public

# Prefix API za reverse proxy (Caddy/Docker: /api, priamy API dev: prázdne)
API_PUBLIC_PREFIX=/api

# Trasy k bodom stretnutia (Directions API). V Docker sa berie z root .env VITE_GOOGLE_MAPS_API_KEY.
GOOGLE_MAPS_API_KEY=
