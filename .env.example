# Skopíruj na .env v root priečinku pred `docker compose up`
JWT_SECRET=change-me-in-production

# Rovnaký kľúč používa mapa v prehliadači. V Google Cloud zapni Maps JavaScript API + Directions API.
VITE_GOOGLE_MAPS_API_KEY=

# Voliteľný kľúč pre server (Directions zo API kontajnera). Ak chýba, použije sa VITE_GOOGLE_MAPS_API_KEY.
# GOOGLE_MAPS_SERVER_API_KEY=

# Google OAuth (voliteľné – prihlásenie menom+heslom funguje aj bez toho)
# Redirect URI: http://localhost:8080/api/auth/callback/google (alebo HTTPS tunel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web Push notifikácie (vygeneruj: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
