# Lokalny dev cez Vite proxy (npm run dev:web + npm run dev:api)
VITE_API_BASE_URL=/api
VITE_GOOGLE_MAPS_API_KEY=

# Google OAuth – Client ID moze byt vo frontende (nie je to secret)
VITE_GOOGLE_CLIENT_ID=

# Volitelne – default je rovnaky origin ako frontend (Caddy / Vite proxy)
# VITE_SOCKET_URL=
